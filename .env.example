# ─── Required ───────────────────────────────────────────
# Your Anthropic API key (get it at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your Solana wallet address (public key only — never the private key!)
SOLANA_WALLET_ADDRESS=YourSolanaWalletAddressHere

# ─── Optional ────────────────────────────────────────────
# Custom agent ID and name (defaults shown)
CLAWPUMP_AGENT_ID=trendhunter-001
CLAWPUMP_AGENT_NAME=TrendHunter

# Cron schedule — default is 10:00 AM UTC daily
# Format: "minute hour day month weekday"
CRON_SCHEDULE=0 10 * * *

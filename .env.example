# ─── Required ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SOLANA_WALLET_ADDRESS=YourSolanaWalletPublicAddressHere

# ─── Auto-payment (IMPORTANT — keeps bot fully automated) ─
# Your wallet's PRIVATE KEY in base58 format
# How to get it: In Phantom wallet → Settings → Export Private Key
# This allows the bot to auto-send 0.03 SOL for each launch
# NEVER share this with anyone — store only in Railway Variables
SOLANA_PRIVATE_KEY=YourBase58PrivateKeyHere

# ─── Images ───────────────────────────────────────────────
# Get free API key at: api.together.xyz (free $1 credit = 500 images)
TOGETHER_API_KEY=your-together-api-key

# ─── Twitter handle (shows on pump.fun coin page, no API needed) ──
TWITTER_HANDLE=yourhandle

# ─── Optional ─────────────────────────────────────────────
CLAWPUMP_AGENT_ID=trendhunter-001
CLAWPUMP_AGENT_NAME=TrendHunter

# Launch time — default 9:30 AM EST (14:30 UTC)
CRON_SCHEDULE=30 14 * * *

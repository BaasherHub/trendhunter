# ─── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SOLANA_WALLET_ADDRESS=YourSolanaWalletPublicAddressHere

# ─── Auto-payment ──────────────────────────────────────────────────────────
# Your wallet's PRIVATE KEY — Phantom: Settings → Export Private Key (base58)
# Allows bot to auto-send SOL for each launch. NEVER share this.
SOLANA_PRIVATE_KEY=YourBase58PrivateKeyHere

# ─── Images ────────────────────────────────────────────────────────────────
# Get free API key at: api.together.xyz
TOGETHER_API_KEY=your-together-api-key

# ─── Twitter handle (shows on pump.fun coin page, no @ needed) ─────────────
TWITTER_HANDLE=Thebaasher

# ─── Grok API (RECOMMENDED — gives real Twitter/Reddit trends) ─────────────
# Get key at: https://console.x.ai → API Keys
# ~$0.01 per trend fetch. Best trend source available.
GROK_API_KEY=xai-...

# ─── ClawPump agent ────────────────────────────────────────────────────────
CLAWPUMP_AGENT_ID=trendhunter-001
CLAWPUMP_AGENT_NAME=TrendHunter

# ─── Schedule ──────────────────────────────────────────────────────────────
# 1 16 * * * = 12:01 PM EST (1 min buffer past 24hr ClawPump cooldown)
CRON_SCHEDULE=1 16 * * *

# ─── Dev buy ───────────────────────────────────────────────────────────────
DEV_BUY_SOL=0.03

# ─── Optional trend sources (fallbacks if Grok not set) ────────────────────
GNEWS_API_KEY=your-gnews-key
APIFY_API_KEY=your-apify-key

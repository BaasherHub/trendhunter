# ─── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SOLANA_WALLET_ADDRESS=YourSolanaWalletPublicAddressHere

# ─── Auto-payment ──────────────────────────────────────────────────────────
# Your wallet's PRIVATE KEY — Phantom: Settings → Export Private Key (base58)
# Allows bot to auto-send SOL for each launch. NEVER share this.
SOLANA_PRIVATE_KEY=YourBase58PrivateKeyHere

# ─── Images ────────────────────────────────────────────────────────────────
# Get free API key at: api.together.xyz
TOGETHER_API_KEY=your-together-api-key

# ─── Twitter handle (shows on pump.fun coin page) ──────────────────────────
# Enter your handle WITHOUT the @ symbol. The bot strips @ automatically.
# This links your token profile to your Twitter/X account after launch.
TWITTER_HANDLE=thebaasher

# ─── Grok API (RECOMMENDED — best source for real Twitter/Reddit trends) ───
# Grok has native real-time access to all X (Twitter) and Reddit data.
# Without this key, the bot falls back to Apify → GNews → Claude → animal fallbacks.
# Get key at: https://console.x.ai → API Keys  (~$0.01 per trend fetch)
GROK_API_KEY=xai-...

# ─── ClawPump agent ────────────────────────────────────────────────────────
CLAWPUMP_AGENT_ID=trendhunter-001
CLAWPUMP_AGENT_NAME=TrendHunter

# ─── Dynamic scheduling ────────────────────────────────────────────────────
# The bot uses dynamic scheduling: each launch triggers the NEXT launch exactly
# 24 hours + 1 minute later, respecting ClawPump's strict 24h cooldown.
# On first run (no history), it defaults to 16:01 UTC (12:01 PM EST).
# On restart, the bot reads launch history and resumes the correct schedule.
# If a launch was due within 5 minutes of restart, it triggers immediately.
LAUNCH_HISTORY_FILE=./launches.json

# ─── Dev buy ───────────────────────────────────────────────────────────────
DEV_BUY_SOL=0.03

# ─── Optional trend sources (fallbacks when GROK_API_KEY is not set) ───────
GNEWS_API_KEY=your-gnews-key
APIFY_API_KEY=your-apify-key

# ─── Required ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SOLANA_WALLET_ADDRESS=YourSolanaWalletAddressHere

# ─── Highly Recommended ───────────────────────────────────
# Free Google Gemini API key for real AI-generated images
# Get it free at: aistudio.google.com → "Get API Key"
GEMINI_API_KEY=AIza...

# Your Twitter/X handle (without @) — shows on pump.fun coin page
# No API needed for this — just your username
TWITTER_HANDLE=yourhandle

# ─── Optional ─────────────────────────────────────────────
CLAWPUMP_AGENT_ID=trendhunter-001
CLAWPUMP_AGENT_NAME=TrendHunter

# Cron schedule — default is 9:30 AM EST (14:30 UTC) daily
CRON_SCHEDULE=30 14 * * *

# ─── One-time use (delete after each launch) ──────────────
# Only needed when ClawPump's free gas is empty
# TX_SIGNATURE=yourSolanaTransactionSignatureHere
